<Window x:Class="VerificarDeXMLNFCE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VerificarDeXMLNFCE"
        mc:Ignorable="d"
        Title="Verificador NFC-e — Consulta SEFAZ"
        Height="780" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117">

    <Window.Resources>
        <!-- Cores -->
        <SolidColorBrush x:Key="AccentBlue"    Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentYellow"  Color="#EAB308"/>
        <SolidColorBrush x:Key="SurfaceDark"   Color="#1A1D27"/>
        <SolidColorBrush x:Key="SurfaceMid"    Color="#22263A"/>
        <SolidColorBrush x:Key="SurfaceLight"  Color="#2A2F45"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#334155"/>

        <!-- Estilo de botão primário -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#3B82F6"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de botão secundário -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#22263A"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"   Value="#2A2F45"/>
                                <Setter Property="BorderBrush"  Value="#475569"/>
                                <Setter Property="Foreground"   Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox estilizado -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background"         Value="#22263A"/>
            <Setter Property="Foreground"         Value="#F1F5F9"/>
            <Setter Property="BorderBrush"        Value="#334155"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="Padding"            Value="10,8"/>
            <Setter Property="CaretBrush"         Value="#3B82F6"/>
            <Setter Property="SelectionBrush"     Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid estilizado -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="Foreground"            Value="#F1F5F9"/>
            <Setter Property="BorderBrush"           Value="#334155"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="RowHeight"             Value="44"/>
            <Setter Property="FontSize"              Value="12.5"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="SelectionUnit"         Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserResizeRows"     Value="False"/>
            <Setter Property="IsReadOnly"            Value="True"/>
            <Setter Property="AlternatingRowBackground" Value="#161922"/>
            <Setter Property="RowBackground"         Value="#1A1D27"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#111827"/>
            <Setter Property="Foreground"    Value="#94A3B8"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="FontSize"      Value="11.5"/>
            <Setter Property="Padding"       Value="12,0"/>
            <Setter Property="Height"        Value="38"/>
            <Setter Property="BorderBrush"   Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E293B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- RadioButton tab style -->
        <Style x:Key="TabRadio" TargetType="RadioButton">
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22263A"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1D27"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#111827" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / Título -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="8" Background="#1D4ED8" Margin="0,0,10,0">
                        <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Verificador NFC-e" FontSize="16" FontWeight="Bold"
                                   Foreground="#F1F5F9" />
                        <TextBlock Text="Consulta SEFAZ — Data de Pagamento" FontSize="10.5"
                                   Foreground="#475569"/>
                    </StackPanel>
                </StackPanel>

                <!-- Badge versão -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Border Background="#1E3A5F" CornerRadius="12" Padding="10,4">
                        <TextBlock Text="v1.0  •  SEFAZ Online" Foreground="#60A5FA" FontSize="11" FontWeight="Medium"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TOOLBAR / INPUTS ═══ -->
        <Border Grid.Row="1" Background="#161922" BorderBrush="#1E293B" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Linha 1: Tabs de modo + botões ação -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Selector de modo -->
                    <Border Grid.Column="0" Background="#0F1117" CornerRadius="9" Padding="4" BorderBrush="#1E293B" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbPasta" Content="📁  Pasta de XMLs" GroupName="Modo"
                                         Style="{StaticResource TabRadio}" IsChecked="True"
                                         Checked="ModoChanged"/>
                            <RadioButton x:Name="rbChaves" Content="🔑  Chaves / Números" GroupName="Modo"
                                         Style="{StaticResource TabRadio}"
                                         Checked="ModoChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- Botões direita -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" >
                        <Button x:Name="btnConsultaIndividual" Content="🔎  Consultar Nota" Style="{StaticResource SecondaryButton}"
                                Click="BtnConsultaIndividual_Click"
                                ToolTip="Abre uma janela para consultar uma nota específica por chave ou XML"/>
                        <Button x:Name="btnLimpar" Content="🗑  Limpar" Style="{StaticResource SecondaryButton}"
                                Click="BtnLimpar_Click"/>
                        <Button x:Name="btnExportar" Content="📥  Exportar CSV" Style="{StaticResource SecondaryButton}"
                                Click="BtnExportar_Click" IsEnabled="False"/>
                        <Button x:Name="btnConsultar" Content="🔍  Consultar" Style="{StaticResource PrimaryButton}"
                                Click="BtnConsultar_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Linha 2: Painel de pasta OU chaves -->
                <Grid Grid.Row="2">
                    <!-- Painel Pasta -->
                    <Grid x:Name="painelPasta" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtPasta" Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="" IsReadOnly="True"
                                 Background="#0F1117"
                                 />
                        <Button Grid.Column="2" Content="  Selecionar Pasta  " Style="{StaticResource SecondaryButton}"
                                Click="BtnSelecionarPasta_Click"/>
                    </Grid>

                    <!-- Painel Chaves -->
                    <Grid x:Name="painelChaves" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtChaves" Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="62"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 ToolTip="Cole as chaves de acesso (44 dígitos) ou números de NF, um por linha"/>
                        <Border Grid.Column="2" Background="#0F1117" CornerRadius="8" Padding="12,8" BorderBrush="#334155" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="💡 Formatos aceitos:" Foreground="#64748B" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="• Chave com 44 dígitos" Foreground="#475569" FontSize="10"/>
                                <TextBlock Text="• Número NF (ex: 000001)" Foreground="#475569" FontSize="10"/>
                                <TextBlock Text="• Um por linha" Foreground="#475569" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ ÁREA PRINCIPAL ═══ -->
        <Grid Grid.Row="2" Margin="20,16,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cards de resumo -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total -->
                <Border Grid.Column="0" Background="#1A1D27" CornerRadius="10" Padding="16,12" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="TOTAL" Foreground="#64748B" FontSize="10" FontWeight="Bold" />
                        <TextBlock x:Name="lblTotal" Text="0" FontSize="28" FontWeight="Bold" Foreground="#F1F5F9" Margin="0,2,0,0"/>
                        <TextBlock Text="notas carregadas" Foreground="#475569" FontSize="10.5"/>
                    </StackPanel>
                </Border>

                <!-- Com pagamento -->
                <Border Grid.Column="2" Background="#0F2A1A" CornerRadius="10" Padding="16,12" BorderBrush="#166534" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="EMITIDAS / AUTORIZADAS" Foreground="#15803D" FontSize="10" FontWeight="Bold" />
                        <TextBlock x:Name="lblComPagamento" Text="0" FontSize="28" FontWeight="Bold" Foreground="#22C55E" Margin="0,2,0,0"/>
                        <TextBlock Text="cStat 100 no XML" Foreground="#166534" FontSize="10.5"/>
                    </StackPanel>
                </Border>

                <!-- Sem pagamento -->
                <Border Grid.Column="4" Background="#2A0F0F" CornerRadius="10" Padding="16,12" BorderBrush="#7F1D1D" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="NÃO EMITIDAS / CANCELADAS" Foreground="#B91C1C" FontSize="10" FontWeight="Bold" />
                        <TextBlock x:Name="lblSemPagamento" Text="0" FontSize="28" FontWeight="Bold" Foreground="#EF4444" Margin="0,2,0,0"/>
                        <TextBlock Text="canceladas ou sem protocolo" Foreground="#7F1D1D" FontSize="10.5"/>
                    </StackPanel>
                </Border>

                <!-- Erro / Pendente -->
                <Border Grid.Column="6" Background="#1A1500" CornerRadius="10" Padding="16,12" BorderBrush="#713F12" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="ERROS / PENDENTES" Foreground="#A16207" FontSize="10" FontWeight="Bold" />
                        <TextBlock x:Name="lblErros" Text="0" FontSize="28" FontWeight="Bold" Foreground="#EAB308" Margin="0,2,0,0"/>
                        <TextBlock Text="falha na consulta" Foreground="#713F12" FontSize="10.5"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tabela -->
            <Border Grid.Row="2" Background="#1A1D27" CornerRadius="10" BorderBrush="#334155" BorderThickness="1"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho da tabela -->
                    <Border Grid.Row="0" Background="#111827" Padding="16,10" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Resultado da Consulta" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
                                <Border Background="#1E293B" CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                                    <TextBlock x:Name="lblContagem" Text="0 registros" Foreground="#64748B" FontSize="10.5"/>
                                </Border>
                            </StackPanel>
                            <!-- Filtro de status -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                                <TextBlock Text="Filtrar:" Foreground="#64748B" FontSize="11.5" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbFiltro" Width="160" SelectionChanged="FiltroChanged"
                                          Background="#22263A" Foreground="#F1F5F9" BorderBrush="#334155"
                                          FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid x:Name="dgResultados" Grid.Row="1"
                              ScrollViewer.CanContentScroll="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              MouseRightButtonUp="DgResultados_MouseRightButtonUp"
                              MouseDoubleClick="DgResultados_MouseDoubleClick"
                              Margin="0"
                              ToolTip="Clique duplo em uma linha para ver os detalhes completos da nota">
                        <DataGrid.Columns>
                            <!-- # -->
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="48">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Status -->
                            <DataGridTemplateColumn Header="Status" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="8,3" Margin="8,0"
                                                Background="{Binding StatusBackground}"
                                                VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusForeground}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- NF / Chave -->
                            <DataGridTextColumn Header="Nº Nota / Chave de Acesso" Binding="{Binding ChaveResumida}" Width="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CBD5E1"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                        <Setter Property="FontSize" Value="11.5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Emitente -->
                            <DataGridTextColumn Header="Emitente (CNPJ)" Binding="{Binding Emitente}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Data Emissão -->
                            <DataGridTextColumn Header="Data Emissão" Binding="{Binding DataEmissao}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Data Pagamento SEFAZ -->
                            <DataGridTemplateColumn Header="Data Pagamento (SEFAZ)" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DataPagamento}"
                                                   Foreground="{Binding PagamentoForeground}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="{Binding PagamentoFontWeight}"
                                                   Margin="0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Valor -->
                            <DataGridTextColumn Header="Valor Total" Binding="{Binding ValorTotal}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#60A5FA"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Fonte -->
                            <DataGridTextColumn Header="Fonte" Binding="{Binding Fonte}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Observação -->
                            <DataGridTextColumn Header="Observação" Binding="{Binding Observacao}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Overlay de estado vazio -->
                    <Grid x:Name="overlayVazio" Grid.Row="1" IsHitTestVisible="False">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5">
                            <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nenhum resultado ainda" Foreground="#475569" FontSize="15"
                                       HorizontalAlignment="Center" Margin="0,8,0,4"/>
                            <TextBlock Text="Selecione uma pasta ou informe chaves e clique em Consultar"
                                       Foreground="#334155" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Overlay de progresso -->
                    <Grid x:Name="overlayProgresso" Grid.Row="1" Visibility="Collapsed"
                          Background="#CC0F1117">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="lblProgresso" Text="Processando…" Foreground="#F1F5F9"
                                       FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <ProgressBar x:Name="progressBar" Width="340" Height="6" Margin="0,16,0,8"
                                         Background="#1E293B" Foreground="#3B82F6"
                                         BorderThickness="0" Maximum="100"/>
                            <TextBlock x:Name="lblSubProgresso" Text="" Foreground="#64748B"
                                       FontSize="12" HorizontalAlignment="Center"/>
                            <Button Content="Cancelar" Style="{StaticResource SecondaryButton}"
                                    Margin="0,16,0,0" Click="BtnCancelar_Click"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="#0A0D13" BorderBrush="#1E293B" BorderThickness="0,1,0,0" Padding="20,6">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
